{
  "name": "@dotgui/kit",
  "version": "0.1.0",
  "description": "The dotgui engine in one package: parser, validator, HTML renderer, and CCAC quality scorer.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/schema/types.ts",
    "./validate": "./src/schema/validate.ts",
    "./parser": "./src/parser/index.ts",
    "./render": "./src/render/index.ts",
    "./score": "./src/score/index.ts",
    "./package": "./src/package/index.ts",
    "./lint": "./src/lint/index.ts",
    "./autofix": "./src/autofix/index.ts",
    "./rasterize": "./src/rasterize/index.ts"
  },
  "bin": {
    "gui-score": "./src/score/cli.ts"
  },
  "files": [
    "src/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "gen:spec": "bun run scripts/gen-spec.ts",
    "gen:spec:check": "bun run scripts/gen-spec.ts && git -C ../core diff --exit-code spec/spec.json",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:render",
    "build:render": "bun build ./src/render/index.ts --outfile ./dist/render.js --format esm",
    "prepublishOnly": "bun run build:render"
  },
  "keywords": ["dotgui", "gui", "parser", "render", "validate", "score"],
  "repository": {
    "type": "git",
    "url": "https://github.com/barrel/dotgui"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2",
    "@xmldom/xmldom": "^0.9.10",
    "fflate": "^0.8.3",
    "happy-dom": "^20.10.3",
    "puppeteer-core": "^25.1.0"
  },
  "optionalDependencies": {
    "gui-optimizer": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  }
}
